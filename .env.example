# Copy this file to .env.local and fill in your values.
# Next.js loads .env.local automatically; it is gitignored so your keys stay private.
# (This .env.example is a safe, secret-free template that CAN be committed.)

# Supabase project URL — base URL only, WITHOUT a trailing /rest/v1.
# Find it: Project Settings -> Data API -> URL (or the "Connect" button).
# Public value, safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon / publishable key (public, browser-safe).
# Find it: Project Settings -> API Keys -> anon public (or "Publishable" key).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Supabase service-role / secret key — SERVER ONLY. Never expose to the browser.
# Find it: Project Settings -> API Keys -> service_role (or "Secret" key).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# Resend API key for transactional email (optional until you wire email features).
# https://resend.com -> API Keys
RESEND_API_KEY=your-resend-api-key
